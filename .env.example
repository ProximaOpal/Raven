# ─────────────────────────────────────────────────────────────────
# Raven AI CCTV — Environment Variables
# Copy to .env and fill in real values. Demo mode works without them.
# ─────────────────────────────────────────────────────────────────

# ── DEMO / MOCK MODE ─────────────────────────────────────────────
# Set to "true" to run without real API keys (uses mock responses)
DEMO_MODE=true

# ── OPENCLAW GATEWAY ──────────────────────────────────────────────
OPENCLAW_GATEWAY_TOKEN=your-openclaw-gateway-token
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789

# ── QWEN / DASHSCOPE ─────────────────────────────────────────────
DASHSCOPE_API_KEY=sk-your-dashscope-key-here
DASHSCOPE_OPENAI_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# Primary model (falls back to qwen-vl-plus if quota exceeded)
QWEN_VL_MODEL=qwen-vl-max
QWEN_PLUS_MODEL=qwen-plus

# ── DATABASE ─────────────────────────────────────────────────────
# SQLite (dev/demo — zero config):
DATABASE_URL=sqlite+aiosqlite:///./raven.db
# PostgreSQL (production):
# DATABASE_URL=postgresql+asyncpg://raven:password@localhost:5432/raven

# ── SECURITY / JWT ───────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── TWILIO SMS ───────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+1234567890
ALERT_TO_NUMBER=+1234567890

# ── SENDGRID EMAIL ────────────────────────────────────────────────
SENDGRID_API_KEY=SG.your-sendgrid-api-key
ALERT_FROM_EMAIL=raven@yourdomain.com
ALERT_TO_EMAIL=soc@yourdomain.com

# ── ALIBABA CLOUD OSS ─────────────────────────────────────────────
OSS_ACCESS_KEY_ID=your-oss-access-key-id
OSS_ACCESS_KEY_SECRET=your-oss-access-key-secret
OSS_BUCKET_NAME=raven-cctv-evidence
OSS_ENDPOINT=https://oss-ap-southeast-1.aliyuncs.com

# ── REDIS (Celery broker) ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── APP ───────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true
LOG_LEVEL=INFO
